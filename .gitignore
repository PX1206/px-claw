```gitignore
# =========================================
# OS
# =========================================
.DS_Store
Thumbs.db
desktop.ini

# =========================================
# Logs
# =========================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================================
# IntelliJ IDEA
# =========================================
.idea/
*.iws
*.iml
*.ipr
out/

# =========================================
# VS Code
# =========================================
.vscode/

# =========================================
# Eclipse / STS
# =========================================
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# =========================================
# NetBeans
# =========================================
/nbproject/private/
/nbbuild/
/nbdist/
/.nb-gradle/

# =========================================
# Maven / Java
# =========================================
target/
!**/src/main/**/target/
!**/src/test/**/target/

*.jar
*.war
*.ear

# Maven Wrapper
!.mvn/wrapper/maven-wrapper.jar

# =========================================
# Gradle
# =========================================
.gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# =========================================
# Node.js
# =========================================
node_modules/
npm-cache/
.pnpm-store/

# =========================================
# Electron Build
# =========================================
dist/
release/
out/
win-unpacked/
*.blockmap

# Electron Builder
electron-builder-cache/

# =========================================
# Python
# =========================================
__pycache__/
*.py[cod]
*$py.class

# Virtual Environment
venv/
.venv/
env/
ENV/

# Python Build
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/

*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# =========================================
# AI / LLM Models
# =========================================
models/
*.gguf
*.bin
*.safetensors
*.pth
*.onnx

# HuggingFace Cache
.huggingface/
cache/

# =========================================
# Binary Files
# =========================================
*.exe
*.dll
*.so
*.dylib
*.zip
*.7z
*.rar
*.tar
*.gz

# =========================================
# Temporary Files
# =========================================
tmp/
temp/
*.tmp
*.swp
*.swo

# =========================================
# Runtime / Database
# =========================================
*.db
*.sqlite
*.sqlite3

# =========================================
# Environment Variables
# =========================================
.env
.env.*
!.env.example

# =========================================
# Mac
# =========================================
.AppleDouble
.LSOverride

# =========================================
# Linux
# =========================================
*~

# =========================================
# Windows
# =========================================
ehthumbs.db
Icon?
```
